---
import Search from "lucide-astro/Search";
import Layout from "@/layouts/Main.astro";
---

<Layout>
  <div class="flex-1 flex flex-col items-center justify-center px-4">
    <h1 class="text-5xl md:text-7xl font-extrabold text-text tracking-tighter mb-12 uppercase">
      Interstellar
    </h1>
    <p id="tagline" class="min-h-[1.5rem] mb-6 -mt-10 text-base md:text-lg text-text-secondary/80 tracking-wide leading-6 opacity-0 transition-opacity duration-150"></p>

    <div class="w-full max-w-2xl">
      <div class="relative">
        <Search
          class="absolute left-4 top-1/2 -translate-y-1/2 h-5 w-5 text-text-secondary"
          strokeWidth={2}
        />
        <input
          id="search"
          class="w-full h-14 pl-12 pr-5 rounded-lg bg-white/5 border border-white/10 text-base text-text placeholder:text-text-placeholder focus:outline-none focus:border-white/25 focus:bg-white/[0.07]"
          placeholder="Search or enter URL"
          type="search"
          autocomplete="off"
          spellcheck="false"
        />
      </div>
    </div>
  </div>
</Layout>
<script src="@/lib/home.ts"></script>
